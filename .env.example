# ==========================================
# OpenRank / Agent-Code environment template
# Copy this file to backend/.env (or project root .env) and fill values.
# Never commit real secrets.
# ==========================================

# --- LLM Provider (Groq) ---
# Required by backend/agent_core.py
GROQ_API_KEY=your_groq_api_key_here

# --- Supabase ---
# Required by backend/database.py
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_key_here
